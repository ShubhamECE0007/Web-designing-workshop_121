<!DOCTYPE html>
<html>
<head>
    <title>Print 1 to 10</title>
</head>
<body>
    <h2>Numbers from 1 to 10:</h2>
    <div id="output"></div>

    <script>
        try {
            let output = "";
            // Loop from 1 to 10
            for (let i = 1; i <= 10; i++) {
                output += i + "<br>"; // Append number with line break
            }
            // Display the result in the webpage
            document.getElementById("output").innerHTML = output;
        } catch (error) {
            console.error("An error occurred:", error);
        }
    </script>
</body>
</html>
